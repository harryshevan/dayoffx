{
  "name": "dayoffs-mcp-tools",
  "version": "2.0.0",
  "authentication": {
    "type": "http_bearer",
    "header": "Authorization",
    "format": "Bearer <token>",
    "notes": "Use a valid MCP token as Bearer token (issued tokens use dof_<tokenId>_<secret>). Admin tools require ADMIN_SECRET."
  },
  "tools": [
    {
      "name": "admin.user.create",
      "arguments": {
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional",
        "goal": "cursor|claude_desktop|other optional"
      },
      "behavior": "Env-admin only. Creates a member via private API and returns a new MCP token."
    },
    {
      "name": "vacation.create",
      "arguments": {
        "from": "YYYY-MM-DD",
        "to": "YYYY-MM-DD",
        "reason": "string",
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional"
      },
      "behavior": "Creates pending vacation for token owner."
    },
    {
      "name": "vacation.update",
      "arguments": {
        "vacationId": "uuid",
        "newFrom": "YYYY-MM-DD",
        "newTo": "YYYY-MM-DD",
        "newReason": "string",
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional"
      },
      "behavior": "Changes token owner's vacation and resets status to pending."
    },
    {
      "name": "vacation.delete",
      "arguments": {
        "vacationId": "uuid",
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional"
      },
      "behavior": "Removes token owner's vacation."
    },
    {
      "name": "config.color.set",
      "arguments": {
        "newColor": "#RRGGBB"
      },
      "behavior": "Changes token owner's profile color."
    },
    {
      "name": "config.displayName.set",
      "arguments": {
        "newName": "string"
      },
      "behavior": "Changes token owner's display name."
    },
    {
      "name": "admin.vacation.approve",
      "arguments": {
        "vacationId": "uuid"
      },
      "behavior": "Admin-only. Approves vacation and writes audit record."
    },
    {
      "name": "admin.token.issue",
      "arguments": {
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional",
        "goal": "cursor|claude_desktop|other optional"
      },
      "behavior": "Admin-only. Uses env ADMIN_SECRET as caller token and issues a new member token."
    },
    {
      "name": "admin.token.revoke",
      "arguments": {
        "token": "string"
      },
      "behavior": "Admin-only. Revokes active member token."
    }
  ]
}
