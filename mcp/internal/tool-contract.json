{
  "name": "dayoffs-mcp-tools",
  "version": "1.0.0",
  "authentication": {
    "type": "token",
    "field": "token",
    "notes": "Use member token from /v1/connect response."
  },
  "tools": [
    {
      "name": "createVacation",
      "arguments": {
        "from": "YYYY-MM-DD",
        "to": "YYYY-MM-DD",
        "reason": "string",
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional"
      },
      "behavior": "Creates pending vacation for token owner."
    },
    {
      "name": "changeVacation",
      "arguments": {
        "vacationId": "uuid",
        "newFrom": "YYYY-MM-DD",
        "newTo": "YYYY-MM-DD",
        "newReason": "string",
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional"
      },
      "behavior": "Changes token owner's vacation and resets status to pending."
    },
    {
      "name": "removeVacation",
      "arguments": {
        "vacationId": "uuid",
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional"
      },
      "behavior": "Removes token owner's vacation."
    },
    {
      "name": "approveVacation",
      "arguments": {
        "vacationId": "uuid"
      },
      "behavior": "Admin-only. Approves vacation and writes audit record."
    },
    {
      "name": "issueToken",
      "arguments": {
        "displayName": "string optional",
        "colorHex": "#RRGGBB optional",
        "goal": "cursor|claude_desktop|other optional"
      },
      "behavior": "Admin-only. Uses env ADMIN_SECRET as caller token and issues a new member token."
    },
    {
      "name": "revokeToken",
      "arguments": {
        "token": "string"
      },
      "behavior": "Admin-only. Revokes active member token."
    }
  ]
}
